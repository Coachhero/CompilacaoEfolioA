real media(real v[], inteiro tamanho);
vazio principal(vazio);

real media(real v[], inteiro tamanho) {
    inteiro i;
    real soma = 0;

    para (i = 0; i < tamanho; i = i + 1) {
        soma = soma + v[i];
    }

    retornar soma / tamanho;
}

vazio principal(vazio) {
    inteiro n;
    real v[5];

    n = 5;
    v[0] = 10;
    v[1] = 20;
    v[2] = 30;
    v[3] = 40;
    v[4] = 50;

    escrever(media(v, n));
}